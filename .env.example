# =============================================================================
# Teacher Tool - Variables de entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores según tu configuración.
# NO commits este archivo al control de versiones - está en .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# API de OpenRouter
# -----------------------------------------------------------------------------
# Clave API para conectar con OpenRouter (proveedor de modelos IA).
# Obtenla en: https://openrouter.ai/keys
# Modelos disponibles:
#   - anthropic/claude-sonnet-4-6 (recomendado)
#   - minimax/minimax-01 (alternativa)
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Configuración del servidor
# -----------------------------------------------------------------------------
# Puerto donde se ejecutará el servidor backend de Express.
# El frontend (Vite) usa el puerto 5173 por defecto.
PORT=3001

# -----------------------------------------------------------------------------
# Base de datos SQLite
# -----------------------------------------------------------------------------
# Ruta relativa o absoluta al archivo de la base de datos SQLite.
# Se creará automáticamente en el primer inicio si no existe.
# Formato: ruta válida del sistema de archivos.
DB_PATH=./database/teacher_tool.db

# -----------------------------------------------------------------------------
# Almacenamiento de archivos
# -----------------------------------------------------------------------------
# Ruta relativa o absoluta al directorio de almacenamiento.
# Se usará para:
#   - Archivos subidos temporalmente (uploads/)
#   - Archivos DOCX generados (generated/)
# El directorio se creará automáticamente si no existe.
STORAGE_PATH=./storage

# -----------------------------------------------------------------------------
# LibreOffice (conversión de .doc)
# -----------------------------------------------------------------------------
# Ruta al ejecutable de LibreOffice para convertir archivos .doc a .docx.
# Ajusta esta ruta si LibreOffice está instalado en otra ubicación.
# Versión recomendada: 24.x o superior.
# En Linux常见的 rutas:
#   - /usr/bin/libreoffice
#   - /opt/libreoffice/program/soffice
# En Windows:
#   - C:\Program Files\LibreOffice\program\soffice.exe
LIBREOFFICE_PATH=/usr/bin/libreoffice